+	requireAutoDetectedProvider(t, providers, schemas.Fireworks, "FIREWORKS_API_KEY", "fireworks-test-key")
+	requireAutoDetectedProvider(t, providers, schemas.Gemini, "GEMINI_API_KEY", "gemini-test-key")
